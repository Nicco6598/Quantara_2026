{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quantara",
  "version": "0.1.0",
  "identifier": "com.quantara.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quantara",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2MEY1MkNCMEUzQzU5NUUKUldSZVdUd095MUlQUm1MMWRQOTNOUG5JaEc2K1JJVGtYWDBOTGtFSExVTlpaV3cwTS9UTUpTQ3IK",
      "endpoints": [
        "https://your-server.com/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}