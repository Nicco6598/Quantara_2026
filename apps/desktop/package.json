{
  "name": "@quantara/desktop",
  "version": "0.5.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:check": "vite build && node ../../scripts/check-bundle-size.mjs",
    "build:analyze": "vite build --mode analyze && node ../../scripts/check-bundle-size.mjs",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@quantara/domain-utils": "workspace:*",
    "@quantara/excel-import": "workspace:*",
    "@quantara/pdf-export": "workspace:*",
    "@quantara/shared-types": "workspace:*",
    "@quantara/ui-tokens": "workspace:*",
    "@quantara/validation": "workspace:*",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "uplot": "^1.6.32",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "^25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "^29.1.1",
    "knip": "^6.13.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
